<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.10xoss.crop-guide-overlay</string>
  <key>ProgramArguments</key>
  <array>
    <string>__APP_PATH__/Contents/MacOS/CropGuideOverlay</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>ProcessType</key>
  <string>Interactive</string>
  <key>StandardOutPath</key>
  <string>/tmp/crop-guide-overlay.out.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/crop-guide-overlay.err.log</string>
</dict>
</plist>
